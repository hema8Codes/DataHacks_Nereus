# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to git.
#
# Get keys at:
#   Gemini      — https://aistudio.google.com/apikey       (free tier)
#   Anthropic   — https://console.anthropic.com/           ($5 free credit on signup)
#   ElevenLabs  — https://elevenlabs.io/app/agents         (create a Conversational AI agent)

GEMINI_API_KEY=your_gemini_api_key_here
ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id_here

# Optional — enables Claude for PDF intelligence briefings (/report endpoint).
# If unset, /report falls back to Gemini.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
